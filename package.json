{
  "name": "ap-study-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build",
    "build:ext": "esbuild extension/src/content.ts extension/src/background.ts --bundle --outdir=extension/runtime --target=chrome110 --format=iife --platform=browser --charset=utf8",
    "preview": "vite preview",
    "test": "vitest run --dir src"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "dexie": "^4.0.11",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
